# --- Client (safe to expose; Vite inlines VITE_* into the browser bundle) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Server only: used by api/compose-email.js (the AI email feature) ---
# These MUST NOT be prefixed with VITE_ — that would inline them into the
# browser bundle and leak your Cloudflare token to anyone viewing the page.
# Optional: the AI feature is the only thing that needs them.
CF_ACCOUNT_ID=
CF_API_TOKEN=
# Same value as VITE_FIREBASE_PROJECT_ID; used to verify the caller's ID token.
FIREBASE_PROJECT_ID=
# Optional override; defaults to @cf/meta/llama-3.1-8b-instruct
CF_AI_MODEL=
