rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(employeeId) {
      return isSignedIn() && request.auth.uid == employeeId;
    }

    // --- users --------------------------------------------------------
    // Any authenticated user may read their own profile; admin may read/write all.
    // Employees may update their own doc but never their role, leave entitlements,
    // or the opening leave-taken figures (either would let them inflate their balance).
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isOwner(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.leaveEntitlements == resource.data.leaveEntitlements &&
        request.resource.data.get('leaveOpeningTaken', {}) == resource.data.get('leaveOpeningTaken', {})
      );
      allow delete: if isAdmin();
    }

    // --- performance ------------------------------------------------------
    // Reviews are admin-authored only. Achievements are self-logged wins:
    // employees may create their own (entryType == 'Achievement') but never
    // edit or delete any performance doc once created.
    match /performance/{id} {
      allow read: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (
        isOwner(request.resource.data.employeeId) &&
        request.resource.data.entryType == 'Achievement'
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- recognitions -------------------------------------------------------
    // Anyone (admin or employee) may recognize a teammate, but never themselves.
    // Readable by the recipient, the giver, or admin. Only admin may edit/delete.
    match /recognitions/{id} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.employeeId == request.auth.uid ||
        resource.data.givenByUid == request.auth.uid
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.givenByUid &&
        request.resource.data.employeeId != request.resource.data.givenByUid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- feedback -----------------------------------------------------------
    // Admin-authored only: employees may read their own entries, never write.
    match /feedback/{id} {
      allow read: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // --- grievances -----------------------------------------------------
    // Employees may read their own and create new ones (forced to 'Open'), but
    // only admin may change status/resolution/priority/assignee/SLA or delete.
    match /grievances/{id} {
      allow read: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (
        isOwner(request.resource.data.employeeId) &&
        request.resource.data.status == 'Open'
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Comment thread on a grievance. The employee it concerns and the admin
      // may both read and post; each comment carries its author, and only the
      // author (or admin) may edit or delete it.
      match /comments/{commentId} {
        function isGrievanceParticipant() {
          return isSignedIn() && (
            isAdmin() ||
            get(/databases/$(database)/documents/grievances/$(id)).data.employeeId == request.auth.uid
          );
        }
        allow read: if isGrievanceParticipant();
        allow create: if isGrievanceParticipant() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      }
    }

    // --- leaves -----------------------------------------------------------
    // Employees may read their own and create new requests (forced to 'Pending'),
    // but only admin may approve/reject (update status/approvedBy) or delete.
    match /leaves/{id} {
      allow read: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (
        isOwner(request.resource.data.employeeId) &&
        request.resource.data.status == 'Pending'
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- goals / OKRs -----------------------------------------------------
    // Objectives with embedded key results. Collaborative: the employee and the
    // admin may both create, edit (incl. ticking key results) and delete an
    // employee's goals. The employee can't reassign a goal to someone else.
    match /goals/{id} {
      allow read: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || isOwner(request.resource.data.employeeId);
      allow update: if isAdmin() || (
        isOwner(resource.data.employeeId) &&
        request.resource.data.employeeId == resource.data.employeeId
      );
      allow delete: if isAdmin() || isOwner(resource.data.employeeId);
    }

    // --- bookmarks --------------------------------------------------------
    // Admin-curated useful links, visible to the whole team. Any signed-in user
    // may read; only admin may add, edit or remove.
    match /bookmarks/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- one-on-ones ------------------------------------------------------
    // A collaborative 1:1 between the admin and one employee. The parent doc
    // holds metadata + a shared agenda; notes and action items live in
    // subcollections so per-author integrity can be enforced (an employee can't
    // edit or delete the manager's note, and vice versa). Anyone in the 1:1 may
    // tick an action item done.
    match /oneOnOnes/{id} {
      // A participant of *this* 1:1 (admin, or the employee it's about).
      function isParticipant() {
        return isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      }
      // Same check for a not-yet-created parent (used by subcollection rules via get()).
      function isParticipantOf(pid) {
        return isSignedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/oneOnOnes/$(pid)).data.employeeId == request.auth.uid
        );
      }

      allow read: if isParticipant();
      allow create: if isAdmin() || isOwner(request.resource.data.employeeId);
      // Admin can edit anything. The employee participant may edit the shared
      // agenda but not reassign the 1:1 or rewrite its metadata.
      allow update: if isAdmin() || (
        isOwner(resource.data.employeeId) &&
        request.resource.data.employeeId == resource.data.employeeId &&
        request.resource.data.date == resource.data.date &&
        request.resource.data.createdBy == resource.data.createdBy
      );
      allow delete: if isAdmin();

      // Notes: each carries its author. You may only create your own; only the
      // author (or admin) may edit or delete it.
      match /notes/{noteId} {
        allow read: if isParticipantOf(id);
        allow create: if isParticipantOf(id) && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      }

      // Action items: anyone in the 1:1 may toggle `done`; only the creator (or
      // admin) may change the text/owner or delete.
      match /actions/{actionId} {
        allow read: if isParticipantOf(id);
        allow create: if isParticipantOf(id) && request.resource.data.createdByUid == request.auth.uid;
        allow update: if isAdmin() ||
          (isSignedIn() && resource.data.createdByUid == request.auth.uid) ||
          (isParticipantOf(id) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['done']));
        allow delete: if isAdmin() || (isSignedIn() && resource.data.createdByUid == request.auth.uid);
      }
    }
  }
}
